# ============================================
# RAVEN STORE — Environment Variables
# Salin file ini ke .env.local lalu isi nilainya
# ============================================

# === CLERK AUTH ===
# Daftar di https://clerk.com → buat app baru
# Pilih Google sebagai social provider
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx

# URL redirect setelah login/logout (Clerk default)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# === DISCORD WEBHOOK ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# === ADMIN ===
# URL admin: domain.com/[ADMIN_SECRET]/admin
ADMIN_SECRET=ganti-ini-string-acak
ADMIN_PASSWORD=password-admin-kamu

# === PAYMENT MANUAL ===
PAYMENT_HOLDER_NAME=Nama Kamu
PAYMENT_DANA=08xxxxxxxxxx
PAYMENT_GOPAY=08xxxxxxxxxx
PAYMENT_QRIS_URL=https://i.imgur.com/your-qris-image.png

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
